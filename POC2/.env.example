# ============================================================
# AI Data Assistant — POC2
# .env.example — copy to .env and fill in your values
#
# NOTE: MSSQL_DATABASE has been REMOVED.
# Database names are now managed in config/databases.json.
# ============================================================

# --- MS SQL Server (server-level credentials) ---
MSSQL_SERVER=your_server_name_or_ip
MSSQL_PORT=1433
MSSQL_USER=your_sql_user
MSSQL_PASSWORD=your_sql_password
MSSQL_DRIVER={ODBC Driver 18 for SQL Server}
MSSQL_TRUST_SERVER_CERTIFICATE=yes

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_assistant_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# --- LDAP ---
LDAP_SERVER=your_ldap_server
LDAP_PORT=389
LDAP_BASE_DN=DC=yourdomain,DC=com
LDAP_DOMAIN=yourdomain.com
LDAP_USER_DN_PATTERN=CN={username},OU=Users,DC=yourdomain,DC=com
LDAP_SERVICE_ACCOUNT_USER=svc_account
LDAP_SERVICE_ACCOUNT_PASSWORD=svc_password
LDAP_USE_SSL=false

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- FastAPI ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Application ---
LOG_LEVEL=INFO
ADMIN_EMAIL=admin@yourinstitution.edu
SECRET_KEY=change_this_to_a_random_secret_key