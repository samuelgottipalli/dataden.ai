# ============================================================
# AI Data Assistant — POC2
# .env.example  —  copy to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# --- MS SQL Server (data warehouse — read-only account) ---
MSSQL_SERVER=your_server_name_or_ip
MSSQL_PORT=1433
MSSQL_DATABASE=your_database_name
MSSQL_USER=your_readonly_user
MSSQL_PASSWORD=your_password
MSSQL_DRIVER={ODBC Driver 18 for SQL Server}
# Set to yes if your SQL Server uses a self-signed certificate (common on local/dev servers)
MSSQL_TRUST_SERVER_CERTIFICATE=yes

# --- PostgreSQL (operational DB — audit logs, RAG store, session data) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_assistant_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# --- LDAP / Active Directory ---
LDAP_SERVER=ldap://your_ad_server
LDAP_PORT=389
LDAP_BASE_DN=DC=yourdomain,DC=com
LDAP_DOMAIN=yourdomain
LDAP_USER_DN_PATTERN=yourdomain\{username}
LDAP_SERVICE_ACCOUNT_USER=svc_ai_assistant@yourdomain.com
LDAP_SERVICE_ACCOUNT_PASSWORD=your_service_account_password
LDAP_USE_SSL=false

# --- Ollama (local LLM) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- FastAPI ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Application ---
LOG_LEVEL=INFO
ADMIN_EMAIL=admin@yourdomain.com
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace_with_generated_secret_key
